{
  "case_id": "md-astropy-13236-add-validators",
  "disallowed_tools": [
    "Bash(*README*)",
    "Bash(*.md*)",
    "Bash(*docs/*)",
    "Bash(find:*)",
    "Bash(ls:*)",
    "Bash(grep:*)",
    "Bash(cat:*)",
    "Bash(head:*)",
    "Bash(tail:*)",
    "Bash(sed:*)",
    "Bash(awk:*)",
    "Read(/testbed/astropy/utils/misc.py)",
    "Read(/testbed/astropy/utils/parsing.py)",
    "Read(/testbed/astropy/utils/codegen.py)",
    "Read(/testbed/astropy/utils/collections.py)",
    "Read(/testbed/astropy/utils/argparse.py)",
    "Read(/testbed/astropy/utils/xml/validate.py)",
    "Bash(pip:*)",
    "Bash(pip3:*)",
    "Bash(uv:*)",
    "Bash(poetry:*)",
    "Bash(npm:*)",
    "Bash(pnpm:*)",
    "Bash(yarn:*)",
    "Bash(bun:*)"
  ],
  "rules": [
    {
      "id": "no-unrequested-doc-writes",
      "effect": "block",
      "pattern": "(?:README|\\.md\\b|docs/)\\b",
      "reason": "Do not create documentation or Markdown files unless the task explicitly asks for documentation."
    },
    {
      "id": "no-package-install",
      "effect": "block",
      "pattern": "(^|[;&|()\\s])(?:(?:pip3?|uv|poetry)\\s+(?:install|add)|(?:npm|pnpm|yarn|bun)\\s+(?:install|i|add))\\b",
      "reason": "Do not install or add new package dependencies unless the task explicitly requires dependency changes."
    },
    {
      "id": "no-bash-file-ops",
      "effect": "block",
      "pattern": "(^|[;&|()\\s])(?:find|ls|grep|cat|head|tail|sed|awk)\\b",
      "reason": "Use Task(subagent_type=Explore), Glob, Grep, and Read for repository file/search/listing operations; reserve Bash for pytest and ruff."
    },
    {
      "id": "avoid-unrelated-utils-reads",
      "effect": "block",
      "pattern": "astropy/utils/(misc|parsing|codegen|collections|argparse|xml/validate)\\.py",
      "reason": "Stay focused on validators: read __init__.py, shapes.py, and astropy/utils/tests patterns, then implement validation.py, exports, tests, pytest, and summary."
    }
  ]
}
