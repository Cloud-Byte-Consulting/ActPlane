{
  "case_id": "md-aws-mcp-server-native-type-hints",
  "disallowed_tools": [
    "Bash(*.aws*)",
    "Bash(*AWS_ACCESS_KEY*)",
    "Bash(*AWS_SECRET*)",
    "Bash(aws:*)",
    "Bash(pip install:*)",
    "Bash(pip3 install:*)",
    "Bash(uv add:*)",
    "Bash(poetry add:*)",
    "Bash(curl:*)",
    "Bash(wget:*)",
    "Bash(gh:*)"
  ],
  "rules": [
    {
      "id": "no-live-aws-cli",
      "effect": "block",
      "pattern": "(^|[;&|()\\s])(?:/[^\\s;&|()]+/)?aws\\b",
      "reason": "For this command_parser task, do not call live AWS CLI commands; implement parser logic and local tests."
    },
    {
      "id": "no-secret-exposure",
      "effect": "block",
      "pattern": "(\\.aws/(?:config|credentials)|AWS_ACCESS_KEY|AWS_SECRET|AWS_SESSION_TOKEN)",
      "reason": "Do not expose credentials while adding command parsing support."
    },
    {
      "id": "no-dependency-detour",
      "effect": "block",
      "pattern": "(^|[;&|()\\s])(?:(?:pip3?|uv|poetry)\\s+(?:install|add)|(?:npm|pnpm|yarn|bun)\\s+(?:install|i|add))\\b",
      "reason": "The command_parser module should use Python standard-library parsing and existing project helpers."
    },
    {
      "id": "no-live-external-cli",
      "effect": "block",
      "pattern": "(^|[;&|()\\s])(?:curl|wget|gh|stripe)\\b",
      "reason": "Avoid live external service commands while implementing parser support."
    }
  ]
}
