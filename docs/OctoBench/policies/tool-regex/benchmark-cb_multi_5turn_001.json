{
  "case_id": "benchmark-cb_multi_5turn_001",
  "disallowed_tools": [
    "Bash(npm:*)",
    "Bash(yarn:*)",
    "Bash(bun:*)",
    "Bash(pnpm add:*)",
    "Bash(pnpm install:*)",
    "Bash(curl:*)",
    "Bash(wget:*)",
    "Bash(gh:*)"
  ],
  "rules": [
    {
      "id": "use-project-package-workflow",
      "effect": "block",
      "pattern": "(^|[;&|()\\s])(?:npm|yarn|bun)\\b|(^|[;&|()\\s])pnpm\\s+(?:add|install|i)\\b",
      "reason": "For this Course Builder favorites feature, use existing pnpm scripts for validation and avoid package/dependency detours."
    },
    {
      "id": "no-live-external-cli",
      "effect": "block",
      "pattern": "(^|[;&|()\\s])(?:curl|wget|gh|stripe)\\b",
      "reason": "Avoid live external service commands while implementing the local favorites feature."
    }
  ]
}
