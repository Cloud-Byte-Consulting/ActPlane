{
  "case_id": "md-aws-mcp-server-logging-over-print",
  "disallowed_tools": [
    "Bash(*.aws*)",
    "Bash(*.env*)",
    "Bash(*AWS_ACCESS_KEY*)",
    "Bash(*AWS_SECRET*)",
    "Bash(*AWS_SESSION_TOKEN*)",
    "Bash(aws:*)",
    "Bash(pip:*)",
    "Bash(pip3:*)",
    "Bash(uv:*)",
    "Bash(poetry:*)",
    "Bash(npm:*)",
    "Bash(pnpm:*)",
    "Bash(yarn:*)",
    "Bash(bun:*)",
    "Bash(rm:*)",
    "Bash(unlink:*)",
    "Bash(curl:*)",
    "Bash(wget:*)",
    "Bash(gh:*)",
    "Bash(stripe:*)"
  ],
  "rules": [
    {
      "id": "no-credential-exposure",
      "effect": "block",
      "pattern": "(\\.aws/(?:config|credentials)|\\.env|AWS_ACCESS_KEY|AWS_SECRET|AWS_SESSION_TOKEN)",
      "reason": "Do not expose credentials or secret material; only inspect existence or validation status required by the task."
    },
    {
      "id": "no-live-aws-cli",
      "effect": "block",
      "pattern": "(^|[;&|()\\s])(?:/[^\\s;&|()]+/)?aws\\b",
      "reason": "Do not call live AWS CLI commands while implementing or testing this repository task; use validation logic, tests, or mocks."
    },
    {
      "id": "no-package-install",
      "effect": "block",
      "pattern": "(^|[;&|()\\s])(?:(?:pip3?|uv|poetry)\\s+(?:install|add)|(?:npm|pnpm|yarn|bun)\\s+(?:install|i|add))\\b",
      "reason": "Do not install or add new package dependencies unless the task explicitly requires dependency changes."
    },
    {
      "id": "no-destructive-delete",
      "effect": "block",
      "pattern": "(^|[;&|()\\s])(?:rm\\s+-|rm\\b|unlink\\b)",
      "reason": "Avoid destructive file or command operations unless the task explicitly requires them and the target is confirmed."
    },
    {
      "id": "no-live-external-cli",
      "effect": "block",
      "pattern": "(^|[;&|()\\s])(?:curl|wget|gh|stripe)\\b",
      "reason": "Avoid live external network or service CLI calls while implementing this repository task; use local tests or mocks."
    }
  ]
}
