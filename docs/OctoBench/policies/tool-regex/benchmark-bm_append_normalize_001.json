{
  "case_id": "benchmark-bm_append_normalize_001",
  "disallowed_tools": [
    "Bash(pip install:*)",
    "Bash(pip3 install:*)",
    "Bash(uv add:*)",
    "Bash(poetry add:*)",
    "Bash(curl:*)",
    "Bash(wget:*)",
    "Bash(gh:*)"
  ],
  "rules": [
    {
      "id": "no-dependency-detour",
      "effect": "block",
      "pattern": "(^|[;&|()\\s])(?:(?:pip3?|uv|poetry)\\s+(?:install|add)|(?:npm|pnpm|yarn|bun)\\s+(?:install|i|add))\\b",
      "reason": "The frontmatter normalization feature should use existing Basic Memory utilities and tests."
    },
    {
      "id": "no-live-external-cli",
      "effect": "block",
      "pattern": "(^|[;&|()\\s])(?:curl|wget|gh|stripe)\\b",
      "reason": "Avoid live external service commands while implementing this local normalization feature."
    }
  ]
}
